# Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Flask Configuration
FLASK_APP=main.py
FLASK_ENV=production
SECRET_KEY=replace-with-a-secure-random-secret-key

# Database Configuration
DATABASE_URL=sqlite:///users.db
# For PostgreSQL: postgresql://username:password@localhost:5432/dbname

# Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
MAX_AUDIO_SIZE=52428800  # 50MB in bytes
MAX_CONTENT_LENGTH=209715200  # 200MB in bytes

# Application Settings
DEBUG=False
HOST=0.0.0.0
PORT=5000

# FFmpeg Configuration
FFMPEG_PATH=/usr/bin/ffmpeg  # Adjust based on your system

# Bairan Effect Integration
BAIRAN_EFFECT_API_URL=http://bairaneffect:3001/process
BAIRAN_EFFECT_TIMEOUT=1800
FAL_KEY=replace-with-your-fal-ai-api-key  # required in production

# Storage Paths
UPLOAD_FOLDER=user_uploads
REELS_FOLDER=static/reels
METADATA_FOLDER=static/metadata

# Email Configuration (for future features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# AWS S3 Configuration (optional, for cloud storage)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
